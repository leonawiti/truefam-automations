<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.capmke.linkedinposter</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/leonawiti/Documents/GitHub/Truefam/automations/capmke-linkedin-poster/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/leonawiti/Documents/GitHub/Truefam/automations/capmke-linkedin-poster</string>

    <!-- Run daily at 8:00 AM (system local time = America/Chicago) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- If the Mac was asleep at 8 AM, run as soon as it wakes -->
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/leonawiti/Documents/GitHub/Truefam/automations/capmke-linkedin-poster/logs/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/leonawiti/Documents/GitHub/Truefam/automations/capmke-linkedin-poster/logs/launchd.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
