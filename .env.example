# WhatsApp Status Poster Configuration
# Copy this to .env and fill in the values

# Google Sheet with post content
WHATSAPP_SHEET_ID=1hxuFZ7Ae0RGe0TCKMuGIu9wGjcmiB2e5kRXpzIerCyA

# Path to Google service account JSON key (needs Sheets + Drive API access)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Chrome profile directory (persists WhatsApp Web login session)
CHROME_PROFILE_DIR=./chrome_profile
