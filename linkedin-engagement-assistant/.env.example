# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# LinkedIn Credentials
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password

# Flask Dashboard
FLASK_SECRET_KEY=change-this-to-a-random-string
DASHBOARD_PORT=5000

# Operating Mode: review_first | auto_send | digest
OPERATING_MODE=review_first

# Rate Limiting
MAX_MESSAGES_PER_DAY=20
MIN_DELAY_SECONDS=180

# Persona
PERSONA_REFRESH_INTERVAL_DAYS=30
MIN_MESSAGES_FOR_BASELINE=50

# Logging
LOG_LEVEL=INFO
