# Website Health Monitor configuration
# Copy to .env and fill in your real values

# Recipient of the daily health report
HEALTH_REPORT_RECIPIENT=lawiti@truefamwel.com

# Gmail SMTP credentials (use a Google App Password, not your real password)
# Generate one at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
